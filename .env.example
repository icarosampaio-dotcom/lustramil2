# LustraMil - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores

# Ambiente
NODE_ENV=production

# Banco de Dados
# Para SQLite (desenvolvimento/teste):
DATABASE_URL=file:./data/lustramil.db

# Para MySQL (produção):
# DATABASE_URL=mysql://usuario:senha@host:3306/lustramil

# Segurança
JWT_SECRET=seu-secret-super-seguro-aqui-mude-isso-em-producao

# Aplicação
VITE_APP_ID=lustramil-app
PORT=3000

# OAuth (opcional)
OAUTH_SERVER_URL=https://seu-oauth-server.com
OAUTH_CLIENT_ID=seu-client-id
OAUTH_CLIENT_SECRET=seu-client-secret

# AWS S3 (para upload de arquivos - opcional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=sua-access-key
AWS_SECRET_ACCESS_KEY=sua-secret-key
AWS_S3_BUCKET=seu-bucket

# Google Maps (opcional)
GOOGLE_MAPS_API_KEY=sua-api-key

# Integração Cometa (opcional)
COMETA_API_URL=https://api.cometa.com
COMETA_API_KEY=sua-api-key

# Logging
LOG_LEVEL=info
